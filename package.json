{
  "name": "cts-hackathon",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:ml-models": "node scripts/test-ml-models.mjs",
    "test:ml-models:strict": "set STRICT_PROPHET=true&& node scripts/test-ml-models.mjs",
    "evaluate:ml-models": "cd ml-service && .\\.venv\\Scripts\\python.exe scripts\\evaluate_models.py",
    "evaluate:ml-models:json": "cd ml-service && .\\.venv\\Scripts\\python.exe scripts\\evaluate_models.py --json --out ..\\reports\\ml-evaluation.json",
    "demo:start": "powershell -ExecutionPolicy Bypass -File scripts/demo-start.ps1",
    "demo:validate": "node scripts/demo-validate.mjs",
    "demo:load-check": "node scripts/realtime-load-check.mjs",
    "demo:dashboard-load-check": "node scripts/dashboard-load-check.mjs"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4"
  }
}
